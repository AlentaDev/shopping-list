PORT=3000
CORS_ORIGIN=http://localhost:5173
# Comma-separated list for production (preferred over CORS_ORIGIN)
ALLOWED_ORIGINS=http://localhost:5173
ACCESS_TOKEN_SECRET=dev-access-token-secret-change-me

# Optional. Defaults to "postgres" outside tests.
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopping_list
DB_USER=shopping_list
DB_PASSWORD=shopping_list
DB_SSL=false

# Optional observability (safe placeholders for local setup)
SENTRY_DSN=
SENTRY_RELEASE=local-dev

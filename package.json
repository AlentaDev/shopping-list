{
  "name": "lista-compra",
  "version": "1.0.0",
  "description": "Aplicación para gestionar una lista de la compra",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "web": "pnpm -C apps/web dev",
    "api": "pnpm -C apps/api dev",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @app/api test",
    "test:web": "pnpm --filter @app/web test",
    "test:android": "bash apps/mobile-android/scripts/run-husky-tests.sh",
    "test:e2e": "pnpm -C apps/api database:test:prepare && pnpm playwright test",
    "typecheck": "pnpm -r typecheck",
    "quality": "pnpm -r quality",
    "verify": "pnpm quality && pnpm test:e2e && pnpm -r build",
    "prepare": "husky",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "version:android:sync": "node scripts/sync-android-version.mjs",
    "release:tag": "node scripts/tag-releases.mjs"
  },
  "keywords": [],
  "author": "AlentaDev juangalenta@gmail.com",
  "license": "ISC",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "wait-on": "^9.0.3"
  }
}

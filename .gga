PROVIDER=opencode
RULES_FILE=AGENTS.md
STRICT_MODE=true
TIMEOUT=300

# Revisar solo archivos del stack actual
FILE_PATTERNS=*.ts,*.tsx,*.js,*.jsx

# Evitar ruido de archivos generados/tests tipados
EXCLUDE_PATTERNS=*.d.ts,dist/*,build/*,node_modules/*,apps/mobile-android/**/build/*,apps/mobile-android/.gradle/*,apps/mobile-android/.idea/*,apps/mobile-android/**/*.iml,apps/mobile-android/**/generated/*,apps/mobile-android/**/*.apk,apps/mobile-android/**/*.aab,apps/web/src/shared/services/http/fetchWithAuth.ts
